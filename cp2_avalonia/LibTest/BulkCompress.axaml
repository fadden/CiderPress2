<Window
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:vm="clr-namespace:cp2_avalonia.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:cp2_avalonia.LibTest"
        mc:Ignorable="d"
        x:Class="cp2_avalonia.LibTest.BulkCompress"
        x:DataType="vm:BulkCompressViewModel"
        Title="Bulk Compress Test" Width="1024" Height="640" MinWidth="200" MinHeight="200"
        CanResize="True"
        ShowInTaskbar="False" WindowStartupLocation="CenterOwner"
        Closing="Window_Closing">

    <DockPanel Margin="8">
        <Grid DockPanel.Dock="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Button Grid.Column="0" Grid.Row="0" Name="chooseFileButton" Margin="0,0,16,0"
                    Content="Select File..." Width="120"
                    IsEnabled="{Binding CanChooseFile}"
                    Command="{Binding ChooseFileCommand}"/>
            <TextBox Grid.Column="1" Grid.Row="0" Grid.ColumnSpan="2" Name="pathNameBox"
                     Width="500" HorizontalAlignment="Left"
                     Text="{Binding PathName, UpdateSourceTrigger=PropertyChanged}"/>

            <StackPanel Grid.Column="0" Grid.Row="2" Orientation="Vertical">
                <RadioButton Name="radioCompressSqueeze" GroupName="Comp" Content="_Squeeze"
                             Margin="0,4,0,0" IsCheckedChanged="CompGroup_CheckedChanged"/>
                <RadioButton Name="radioCompressNuLZW1" GroupName="Comp" Content="NuLZW_1"
                             Margin="0,4,0,0" IsCheckedChanged="CompGroup_CheckedChanged"/>
                <RadioButton Name="radioCompressNuLZW2" GroupName="Comp" Content="NuLZW_2"
                             Margin="0,4,0,0" IsCheckedChanged="CompGroup_CheckedChanged"/>
                <RadioButton Name="radioCompressDeflate" GroupName="Comp" Content="_Deflate"
                             Margin="0,4,0,0" IsCheckedChanged="CompGroup_CheckedChanged"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Grid.Row="2" Orientation="Vertical">
                <RadioButton Name="radioCompressLZC12" GroupName="Comp" Content="LZC/12"
                             Margin="0,4,0,0" IsCheckedChanged="CompGroup_CheckedChanged"/>
                <RadioButton Name="radioCompressLZC16" GroupName="Comp" Content="LZC/16"
                             Margin="0,4,0,0" IsCheckedChanged="CompGroup_CheckedChanged"/>
                <RadioButton Name="radioCompressLZHuf" GroupName="Comp" Content="LZHUF"
                             Margin="0,4,0,0" IsCheckedChanged="CompGroup_CheckedChanged"/>
                <RadioButton Name="radioCompressZX0" GroupName="Comp"
                             Content="ZX0 (&quot;quick&quot;)"
                             Margin="0,4,0,0" IsCheckedChanged="CompGroup_CheckedChanged"/>
            </StackPanel>
            <Button Grid.Column="2" Grid.Row="2" Name="runButton"
                    HorizontalAlignment="Left" Margin="16,0,0,0"
                    Content="{Binding RunButtonLabel, FallbackValue=Run Test}"
                    FontWeight="Bold"
                    IsEnabled="{Binding IsRunCancelEnabled}"
                    Command="{Binding RunCancelCommand}"/>
        </Grid>

        <DockPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <Button DockPanel.Dock="Right" Content="Close" Width="70" IsCancel="True"
                        Command="{Binding CloseCommand}"
                    HorizontalAlignment="Right"/>
            <TextBlock Name="progressMsg" Text="{Binding ProgressMsg, FallbackValue=msg here}"/>
        </DockPanel>

        <Border DockPanel.Dock="Top" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="1"
                Margin="0,8,0,0">
            <TextBox Name="logTextBox" IsReadOnly="True"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"/>
        </Border>
    </DockPanel>
</Window>
