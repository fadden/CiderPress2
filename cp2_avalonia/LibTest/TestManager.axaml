<Window
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:vm="clr-namespace:cp2_avalonia.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:cp2_avalonia.LibTest"
        mc:Ignorable="d"
        x:Class="cp2_avalonia.LibTest.TestManager"
        x:DataType="vm:TestManagerViewModel"
        Title="Library Test Runner"
        Width="1024" Height="768" MinWidth="640" MinHeight="480"
        CanResize="True"
        ShowInTaskbar="False" WindowStartupLocation="CenterOwner"
        Closing="Window_Closing">

    <DockPanel Margin="8">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
            <Button Name="runButton" Content="{Binding RunButtonLabel, FallbackValue=Run Test}"
                    Width="120" FontWeight="Bold"
                    Command="{Binding RunCancelCommand}"/>
            <CheckBox Content="Retain output" Margin="20,3,0,0"
                      IsChecked="{Binding IsOutputRetained}"/>
        </StackPanel>

        <Button DockPanel.Dock="Bottom" Content="Close" Width="70" IsCancel="True"
                HorizontalAlignment="Right" Margin="0,8,0,0"
                Command="{Binding CloseCommand}"/>

        <!-- Colored progress output -->
        <ScrollViewer Name="progressScroll"
                      DockPanel.Dock="Top"
                      Height="200" Margin="0,8,0,0"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Background="{DynamicResource ViewerBackgroundBrush}">
            <SelectableTextBlock Name="progressTextBlock"
                                  FontFamily="{DynamicResource GeneralMonoFont}"
                                  FontSize="{DynamicResource ViewerDefaultFontSize}"
                                  TextWrapping="NoWrap"
                                  Padding="4"
                                  Background="Transparent"
                                  MinHeight="{Binding $parent[ScrollViewer].Viewport.Height}"
                                  MinWidth="{Binding $parent[ScrollViewer].Viewport.Width}" />
        </ScrollViewer>

        <ComboBox DockPanel.Dock="Top" Name="outputSelectComboBox"
                  Margin="0,20,0,0" Width="360"
                  HorizontalAlignment="Left"
                  IsEnabled="{Binding IsOutputSelectEnabled}"
                  ItemsSource="{Binding OutputItems}"
                  SelectionChanged="OutputSelectComboBox_SelectedIndexChanged"/>

        <TextBox DockPanel.Dock="Top" Name="outputTextBox"
                 IsReadOnly="True" Margin="0,8,0,0"
                 Text="{Binding SelectedOutputText}"
                 TextWrapping="NoWrap"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"/>
    </DockPanel>
</Window>
