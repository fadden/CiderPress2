<Window xmlns:vm="clr-namespace:cp2_avalonia.ViewModels"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:cp2_avalonia" xmlns:common="clr-namespace:cp2_avalonia.Controls" mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800" x:Class="cp2_avalonia.Views.MainWindow" x:DataType="vm:MainViewModel" Title="{Binding WindowTitle}" Width="1400" Height="900" MinWidth="640" MinHeight="680" Icon="avares://CiderPress2/Res/cp2_app.ico">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://CiderPress2/Res/TreeViewItemStyle.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Window.Styles>
        <!-- Give the pane splitters a visible resting color plus a hover highlight, so it's
             clear they're draggable. -->
        <Style Selector="GridSplitter">
            <Setter Property="Background" Value="{DynamicResource SystemControlForegroundBaseLowBrush}"/>
        </Style>
        <Style Selector="GridSplitter:pointerover">
            <Setter Property="Background" Value="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
        </Style>

        <!-- Options panel show/hide animation.  The ScrollViewer carries the
             "optionsPanelScroll" class always, and the "collapsed" class is bound to the
             inverse of Options.ShowOptionsPanel.  Width + Opacity transition between the two
             states; when collapsed we also set IsEnabled=False so the (zero-width, invisible)
             controls drop out of tab-order and hit-testing, i.e. become truly inactive. -->
        <Style Selector="ScrollViewer.optionsPanelScroll">
            <Setter Property="Width" Value="300"/>
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Width" Duration="0:0:0.25" Easing="CubicEaseInOut"/>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.25" Easing="CubicEaseInOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="ScrollViewer.optionsPanelScroll.collapsed">
            <Setter Property="Width" Value="0"/>
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="IsEnabled" Value="False"/>
        </Style>
    </Window.Styles>

    <Window.KeyBindings>
        <!-- These back the InputGesture hints shown in the classic menu. In Avalonia a menu
             InputGesture only displays text; the actual key handling lives here. -->
        <KeyBinding Gesture="Ctrl+N" Command="{Binding NewDiskImageCommand}"/>
        <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenCommand}"/>
        <KeyBinding Gesture="Ctrl+W" Command="{Binding CloseCommand}"/>
        <KeyBinding Gesture="Ctrl+C" Command="{Binding CopyCommand}"/>
        <KeyBinding Gesture="Ctrl+V" Command="{Binding PasteCommand}"/>
        <KeyBinding Gesture="Ctrl+F" Command="{Binding FindCommand}"/>
        <KeyBinding Gesture="Ctrl+A" Command="{Binding SelectAllCommand}"/>
        <KeyBinding Gesture="F1" Command="{Binding HelpCommand}"/>
        <KeyBinding Gesture="Enter" Command="{Binding ViewFilesCommand}"/>
        <KeyBinding Gesture="Delete" Command="{Binding DeleteFilesCommand}"/>
        <!-- Alt+Up (Go To Parent) is handled in code-behind (Window_PreviewKeyDown, a tunnel
             handler) rather than here, so it runs before the focused tree/grid can eat the Up
             arrow.  See MainWindow.axaml.cs. -->
        <KeyBinding Gesture="Ctrl+I" Command="{Binding ToggleInfoCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+A" Command="{Binding AddFilesCommand}"/>
        <KeyBinding Gesture="Ctrl+E" Command="{Binding ExtractFilesCommand}"/>
        <!-- Alt+Enter = Rename/Edit Attributes (WPF parity); Ctrl+Enter = new viewer. -->
        <KeyBinding Gesture="Alt+Enter" Command="{Binding EditAttributesCommand}"/>
        <KeyBinding Gesture="Ctrl+Enter" Command="{Binding ViewFilesInNewViewerCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+N" Command="{Binding CreateDirectoryCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+W" Command="{Binding CloseSubTreeCommand}"/>
        <KeyBinding Gesture="Ctrl+Alt+A" Command="{Binding ShowAsciiChartCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+T" Command="{Binding Debug_DiskArcLibTestCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+D1" Command="{Binding RecentFile1Command}"/>
        <KeyBinding Gesture="Ctrl+Shift+D2" Command="{Binding RecentFile2Command}"/>
        <KeyBinding Gesture="Ctrl+Shift+D3" Command="{Binding RecentFile3Command}"/>
        <KeyBinding Gesture="Ctrl+Shift+D4" Command="{Binding RecentFile4Command}"/>
        <KeyBinding Gesture="Ctrl+Shift+D5" Command="{Binding RecentFile5Command}"/>
        <KeyBinding Gesture="Ctrl+Shift+D6" Command="{Binding RecentFile6Command}"/>
    </Window.KeyBindings>

    <NativeMenu.Menu>
        <NativeMenu>
            <!-- File -->
            <NativeMenuItem Header="File">
                <NativeMenuItem.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="New Disk Image..." Command="{Binding NewDiskImageCommand}" Gesture="Meta+N"/>
                        <NativeMenuItem Header="New File Archive..." Command="{Binding NewFileArchiveCommand}"/>
                        <NativeMenuItem Header="Open" Command="{Binding OpenCommand}" Gesture="Meta+O"/>
                        <NativeMenuItem Header="Close" Command="{Binding CloseCommand}" Gesture="Meta+W"/>
                        <NativeMenuItemSeparator/>
                        <NativeMenuItem Header="Recent Files">
                            <NativeMenuItem.Menu>
                                <NativeMenu>
                                    <NativeMenuItem Header="(none)" IsEnabled="False"/>
                                </NativeMenu>
                            </NativeMenuItem.Menu>
                        </NativeMenuItem>
                    </NativeMenu>
                </NativeMenuItem.Menu>
            </NativeMenuItem>

            <!-- Edit -->
            <NativeMenuItem Header="Edit">
                <NativeMenuItem.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Copy" Command="{Binding CopyCommand}" Gesture="Meta+C"/>
                        <NativeMenuItem Header="Paste" Command="{Binding PasteCommand}" Gesture="Meta+V"/>
                        <NativeMenuItemSeparator/>
                        <NativeMenuItem Header="Find" Command="{Binding FindCommand}" Gesture="Meta+F"/>
                        <NativeMenuItemSeparator/>
                        <NativeMenuItem Header="Select All" Command="{Binding SelectAllCommand}" Gesture="Meta+A"/>
                    </NativeMenu>
                </NativeMenuItem.Menu>
            </NativeMenuItem>

            <!-- Actions -->
            <NativeMenuItem Header="Actions">
                <NativeMenuItem.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="View Files" Command="{Binding ViewFilesCommand}"/>
                        <NativeMenuItem Header="View Files in New Viewer" Command="{Binding ViewFilesInNewViewerCommand}" Gesture="Ctrl+Enter" />

                        <NativeMenuItem Header="Add Files..." Command="{Binding AddFilesCommand}" Gesture="Meta+Shift+A"/>
                        <NativeMenuItem Header="Import Files..." Command="{Binding ImportFilesCommand}"/>
                        <NativeMenuItem Header="Extract Files..." Command="{Binding ExtractFilesCommand}" Gesture="Meta+E"/>
                        <NativeMenuItem Header="Export Files..." Command="{Binding ExportFilesCommand}"/>
                        <NativeMenuItem Header="Delete Files" Command="{Binding DeleteFilesCommand}"/>
                        <NativeMenuItem Header="Test Files" Command="{Binding TestFilesCommand}"/>
                        <NativeMenuItem Header="Rename / Edit Attributes..." Command="{Binding EditAttributesCommand}" Gesture="Alt+Enter"/>
                        <NativeMenuItem Header="Create Directory..." Command="{Binding CreateDirectoryCommand}" Gesture="Meta+Shift+N"/>
                        <NativeMenuItemSeparator/>
                        <NativeMenuItem Header="Edit Directory Attributes..." Command="{Binding EditDirAttributesCommand}"/>
                        <NativeMenuItemSeparator/>
                        <NativeMenuItem Header="Edit Sectors..." Command="{Binding EditSectorsCommand}"/>
                        <NativeMenuItem Header="Edit Blocks..." Command="{Binding EditBlocksCommand}"/>
                        <NativeMenuItem Header="Save As Disk Image..." Command="{Binding SaveAsDiskImageCommand}"/>
                        <NativeMenuItem Header="Replace Partition Contents..." Command="{Binding ReplacePartitionCommand}"/>
                        <NativeMenuItem Header="Scan for Bad Blocks" Command="{Binding ScanForBadBlocksCommand}"/>
                        <NativeMenuItemSeparator/>
                        <NativeMenuItem Header="Scan for Sub-Volumes" Command="{Binding ScanForSubVolCommand}"/>
                        <NativeMenuItem Header="Defragment Filesystem" Command="{Binding DefragmentCommand}"/>
                        <NativeMenuItem Header="Close File Source" Command="{Binding CloseSubTreeCommand}" Gesture="Meta+Shift+W"/>
                    </NativeMenu>
                </NativeMenuItem.Menu>
            </NativeMenuItem>

            <!-- View -->
            <NativeMenuItem Header="View">
                <NativeMenuItem.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Show Full List" Command="{Binding ShowFullListCommand}"/>
                        <NativeMenuItem Header="Show Directory List" Command="{Binding ShowDirListCommand}"/>
                        <NativeMenuItem Header="Show Information" Command="{Binding ShowInfoCommand}"/>
                    </NativeMenu>
                </NativeMenuItem.Menu>
            </NativeMenuItem>

            <!-- Navigate -->
            <NativeMenuItem Header="Navigate">
                <NativeMenuItem.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Go To Parent Directory" Command="{Binding NavToParentDirCommand}"/>
                        <NativeMenuItem Header="Go To Parent" Command="{Binding NavToParentCommand}"/>
                    </NativeMenu>
                </NativeMenuItem.Menu>
            </NativeMenuItem>
            
            <NativeMenuItem Header="Tools">
                <NativeMenuItem.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="ASCII Chart..." Command="{Binding ShowAsciiChartCommand}" Gesture="Meta+Alt+A"/>
                    </NativeMenu>
                </NativeMenuItem.Menu>
            </NativeMenuItem>
            
            <!-- Help -->
            <NativeMenuItem Header="Help">
                <NativeMenuItem.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Help" Command="{Binding HelpCommand}" Gesture="F1"/>
                    </NativeMenu>
                </NativeMenuItem.Menu>
            </NativeMenuItem>

            <!-- Debug: greyed out (can't IsVisible) when ShowDebugMenu is false -->
            <NativeMenuItem Header="DEBUG" IsEnabled="{Binding ShowDebugMenu}">
                <NativeMenuItem.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="DiskArc Library Tests..." Command="{Binding Debug_DiskArcLibTestCommand}" Gesture="Meta+Shift+T"/>
                        <NativeMenuItem Header="FileConv Library Tests..." Command="{Binding Debug_FileConvLibTestCommand}"/>
                        <NativeMenuItem Header="Bulk Compression Test..." Command="{Binding Debug_BulkCompressTestCommand}"/>
                        <NativeMenuItemSeparator/>
                        <NativeMenuItem Header="System Info..." Command="{Binding Debug_ShowSystemInfoCommand}"/>
                        <NativeMenuItem Header="Show Debug Log" Command="{Binding Debug_ShowDebugLogCommand}" ToggleType="CheckBox" IsChecked="{Binding IsDebugLogVisible}"/>
                        <NativeMenuItem Header="Show Drop/Paste Target" Command="{Binding Debug_ShowDropTargetCommand}" ToggleType="CheckBox" IsChecked="{Binding IsDropTargetVisible}"/>
                        <NativeMenuItemSeparator/>
                        <NativeMenuItem Header="Convert ANI to GIF..." Command="{Binding Debug_ConvertANICommand}"/>
                    </NativeMenu>
                </NativeMenuItem.Menu>
            </NativeMenuItem>
        </NativeMenu>
    </NativeMenu.Menu>

    <Grid>
        <DockPanel>
            <Menu DockPanel.Dock="Top" Name="mainMenu">
                <MenuItem Header="_File">
                    <MenuItem Header="New _Disk Image..." Command="{Binding NewDiskImageCommand}" InputGesture="Ctrl+N"/>
                    <MenuItem Header="_New File Archive..." Command="{Binding NewFileArchiveCommand}"/>
                    <MenuItem Header="_Open" Command="{Binding OpenCommand}" InputGesture="Ctrl+O"/>
                    <MenuItem Name="openPhysicalDriveMenuItem" Header="Open Physical Drive..." Command="{Binding OpenPhysicalDriveCommand}" />
                    <MenuItem Header="_Close" Command="{Binding CloseCommand}" InputGesture="Ctrl+W"/>
                    <Separator/>
                    <MenuItem Name="recentFilesMenu" Header="Recent Files">
                        <MenuItem Header="(none)"/>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="E_xit" Command="{Binding ExitCommand}" InputGesture="Alt+F4"/>
                </MenuItem>

                <MenuItem Header="_Edit">
                    <MenuItem Header="_Copy" Command="{Binding CopyCommand}" InputGesture="Ctrl+C"/>
                    <MenuItem Header="_Paste" Command="{Binding PasteCommand}" InputGesture="Ctrl+V"/>
                    <Separator/>
                    <MenuItem Header="_Find" Command="{Binding FindCommand}" InputGesture="Ctrl+F"/>
                    <Separator/>
                    <MenuItem Header="Select _All" Command="{Binding SelectAllCommand}" InputGesture="Ctrl+A"/>
                    <Separator/>
                    <MenuItem Header="Settings..." Command="{Binding EditAppSettingsCommand}"/>
                </MenuItem>

                <MenuItem Header="_Actions">
                    <MenuItem Header="_View Files" Command="{Binding ViewFilesCommand}" InputGesture="Enter"/>
                    <MenuItem Header="_View Files in New Viewer" Command="{Binding ViewFilesInNewViewerCommand}" InputGesture="Ctrl+Enter"/>
                    <MenuItem Header="_Add Files..." Command="{Binding AddFilesCommand}" InputGesture="Ctrl+Shift+A"/>
                    <MenuItem Header="Import Files..." Command="{Binding ImportFilesCommand}"/>
                    <MenuItem Header="_Extract Files..." Command="{Binding ExtractFilesCommand}" InputGesture="Ctrl+E"/>
                    <MenuItem Header="E_xport Files..." Command="{Binding ExportFilesCommand}"/>
                    <MenuItem Header="_Delete Files" Command="{Binding DeleteFilesCommand}" InputGesture="Delete"/>
                    <MenuItem Header="Test Files" Command="{Binding TestFilesCommand}"/>
                    <MenuItem Header="Rename / Edit Attributes..." Command="{Binding EditAttributesCommand}" InputGesture="Alt+Enter"/>
                    <MenuItem Header="Create Directory..." Command="{Binding CreateDirectoryCommand}" InputGesture="Ctrl+Shift+N"/>
                    <Separator/>
                    <MenuItem Header="Edit Directory Attributes..." Command="{Binding EditDirAttributesCommand}"/>
                    <Separator/>
                    <MenuItem Header="Edit Sectors..." Command="{Binding EditSectorsCommand}"/>
                    <MenuItem Header="Edit Blocks..." Command="{Binding EditBlocksCommand}"/>
                    <MenuItem Header="Save As Disk Image..." Command="{Binding SaveAsDiskImageCommand}"/>
                    <MenuItem Header="Replace Partition Contents..." Command="{Binding ReplacePartitionCommand}"/>
                    <MenuItem Header="Scan for Bad Blocks" Command="{Binding ScanForBadBlocksCommand}"/>
                    <Separator/>
                    <MenuItem Header="Scan for Sub-Volumes" Command="{Binding ScanForSubVolCommand}"/>
                    <MenuItem Header="Defragment Filesystem" Command="{Binding DefragmentCommand}"/>
                    <MenuItem Header="Close File Source" Command="{Binding CloseSubTreeCommand}" InputGesture="Ctrl+Shift+W"/>
                </MenuItem>

                <MenuItem Header="_View">
                    <MenuItem Header="Show Full List" Command="{Binding ShowFullListCommand}"/>
                    <MenuItem Header="Show Directory List" Command="{Binding ShowDirListCommand}"/>
                    <MenuItem Header="Show Information" Command="{Binding ShowInfoCommand}"/>
                </MenuItem>

                <MenuItem Header="_Navigate">
                    <MenuItem Header="Go To Parent Directory" Command="{Binding NavToParentDirCommand}"/>
                    <MenuItem Header="Go To Parent" Command="{Binding NavToParentCommand}" InputGesture="Alt+Up"/>
                </MenuItem>

                <MenuItem Header="_Tools">
                    <MenuItem Header="ASCII Chart..." Command="{Binding ShowAsciiChartCommand}" InputGesture="Ctrl+Alt+A"/>
                </MenuItem>
                
                <MenuItem Header="_Help">
                    <MenuItem Header="Help" Command="{Binding HelpCommand}" InputGesture="F1"/>
                    <MenuItem Header="_About CiderPress II" Command="{Binding AboutCommand}"/>
                </MenuItem>

                <!-- Debug menu: visible only when ShowDebugMenu is true -->
                <MenuItem Header="_DEBUG" IsVisible="{Binding ShowDebugMenu}">
                    <MenuItem Header="DiskArc Library Tests..." Command="{Binding Debug_DiskArcLibTestCommand}" InputGesture="Ctrl+Shift+T"/>
                    <MenuItem Header="FileConv Library Tests..." Command="{Binding Debug_FileConvLibTestCommand}"/>
                    <MenuItem Header="Bulk Compression Test..." Command="{Binding Debug_BulkCompressTestCommand}"/>
                    <Separator/>
                    <MenuItem Header="System Info..." Command="{Binding Debug_ShowSystemInfoCommand}"/>
                    <MenuItem Header="Show Debug Log" Command="{Binding Debug_ShowDebugLogCommand}" IsChecked="{Binding IsDebugLogVisible}" ToggleType="CheckBox"/>
                    <MenuItem Header="Show Drop/Paste Target" Command="{Binding Debug_ShowDropTargetCommand}" IsChecked="{Binding IsDropTargetVisible}" ToggleType="CheckBox"/>
                    <Separator/>
                    <MenuItem Header="Convert ANI to GIF..." Command="{Binding Debug_ConvertANICommand}"/>
                </MenuItem>
            </Menu>

            <!-- Toolbar: replaces WPF ToolBarTray/ToolBar -->
            <Border DockPanel.Dock="Top" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="0,0,0,1" Padding="4,2">
                <StackPanel Orientation="Horizontal" Height="32">
                    <Button Command="{Binding ShowFullListCommand}" ToolTip.Tip="Show full file list" BorderBrush="{Binding FullListBorderBrush}">
                        <Image Source="{StaticResource icon_ListView}" Width="16" Height="16"/>
                    </Button>
                    <Button Command="{Binding ShowDirListCommand}" ToolTip.Tip="Show contents of single directory" BorderBrush="{Binding DirListBorderBrush}">
                        <Image Source="{StaticResource icon_MeasureTree}" Width="16" Height="16"/>
                    </Button>
                    <Button Command="{Binding ShowInfoCommand}" ToolTip.Tip="Show information (toggle: Ctrl+I)" BorderBrush="{Binding InfoBorderBrush}">
                        <Image Source="{StaticResource icon_StatusInformationOutlineNoColor}" Width="16" Height="16"/>
                    </Button>

                    <Border Width="1" Background="{DynamicResource SystemControlForegroundBaseLowBrush}" Margin="4,2"/>

                    <Button Command="{Binding ResetSortCommand}" ToolTip.Tip="Reset the sort order in the file list">
                        <Image Source="{StaticResource icon_ClearSort}" Width="16" Height="16"/>
                    </Button>
                    <Button Command="{Binding NavToParentCommand}" ToolTip.Tip="Move to parent">
                        <Image Source="{StaticResource icon_Upload}" Width="16" Height="16"/>
                    </Button>

                    <Border Width="1" Background="{DynamicResource SystemControlForegroundBaseLowBrush}" Margin="4,2"/>

                    <!-- Drag &amp; copy mode combo box -->
                    <TextBlock Text="Drag &amp; Copy mode:" Margin="4,6,0,0" ToolTip.Tip="Configure behavior when dragging and copying files in or out"/>
                    <ComboBox Margin="4,1,0,0" Width="150" SelectedIndex="{Binding Options.DDCPModeIndex}" ToolTip.Tip="Configure behavior when dragging and copying files in or out.">
                        <ComboBoxItem>Add/Extract</ComboBoxItem>
                        <ComboBoxItem>Import/Export</ComboBoxItem>
                    </ComboBox>
                    <!-- Note: WPF sets BorderBrush on these RadioButtons to
                     {DynamicResource {x:Static SystemColors.MenuHighlightBrushKey}}.
                     Avalonia has no SystemColors — the default Fluent theme styling
                     is sufficient, so this binding is intentionally dropped. -->

                    <Border Width="1" Background="{DynamicResource SystemControlForegroundBaseLowBrush}" Margin="4,2"/>

                    <Button Command="{Binding HelpCommand}" ToolTip.Tip="Help - open manual in browser (F1)">
                        <Image Source="{StaticResource icon_F1Help}" Width="16" Height="16"/>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Status bar -->
            <Border DockPanel.Dock="Bottom" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="0,1,0,0" Padding="4,2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Ready"/>
                    <TextBlock Grid.Column="1" HorizontalAlignment="Center" Text="{Binding StatusBar.CenterText}"/>
                    <TextBlock Grid.Column="2" Name="statusRightText" Text="{Binding StatusBar.RightText}"/>
                </Grid>
            </Border>

            <!-- Main content area.  Must come last in DockPanel for LastChildFill. -->
            <Grid Name="mainGrid">

                <!-- Launch panel: shown when no file is open -->
                <Grid Name="launchPanel" IsVisible="{Binding LaunchPanelVisible}" DragDrop.AllowDrop="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="4*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="4*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Center">
                        <TextBlock Text="CiderPress II" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding ProgramVersionString, StringFormat=Version {0}}" FontSize="24" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <ScrollViewer Grid.Column="1" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel>
                            <Grid Width="400" Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Button Grid.Row="0" Grid.Column="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Content="Create new disk image" Command="{Binding NewDiskImageCommand}"/>

                                <Button Grid.Row="0" Grid.Column="2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Content="Create new file archive" Command="{Binding NewFileArchiveCommand}"/>

                                <Button Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="2"  Content="Open file" Command="{Binding OpenCommand}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>

                                <Button Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="4" HorizontalAlignment="Stretch"  IsVisible="{Binding ShowRecentFile1}" Command="{Binding RecentFile1Command}" ToolTip.Tip="{Binding RecentFilePath1}">
                                    <StackPanel>
                                        <TextBlock HorizontalAlignment="Center">Recent file #1</TextBlock>
                                        <TextBlock Text="{Binding RecentFileName1}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <Button Grid.Column="0" Grid.ColumnSpan="3" Grid.Row="6" HorizontalAlignment="Stretch" IsVisible="{Binding ShowRecentFile2}" Command="{Binding RecentFile2Command}" ToolTip.Tip="{Binding RecentFilePath2}">
                                    <StackPanel>
                                        <TextBlock HorizontalAlignment="Center">Recent file #2</TextBlock>
                                        <TextBlock Text="{Binding RecentFileName2}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <!-- Main triptych panel: shown when a file is open -->
                <Grid Name="mainTriptychPanel" IsVisible="{Binding MainPanelVisible}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="100"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*" MinWidth="150"/>
                        <!-- Right options panel: Auto so it's sized entirely by its content
                             (fixed-width when shown, rotated-button-width when hidden). No
                             GridSplitter here on purpose — the Show/Hide button is the only
                             thing that controls this panel's size. -->
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <GridSplitter Grid.Column="1" Width="4"/>

                    <!-- Left panel: archive tree + directory tree + find bar -->
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" MinHeight="100"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="2*" MinHeight="100"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Archive tree (top-left) -->
                        <Grid Grid.Row="0" Margin="4,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Archive Contents" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                            <Border Grid.Row="1" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="1" CornerRadius="2">
                                <TreeView Name="archiveTree" ItemsSource="{Binding ArchiveTree.TreeRoot}" SelectionChanged="ArchiveTree_SelectionChanged">
                                    <TreeView.ContextMenu>
                                        <!-- Operates on the selected archive/disk/partition node.
                                             Items self-disable via each command's CanExecute. -->
                                        <ContextMenu>
                                            <MenuItem Header="Edit Sectors..." Command="{Binding EditSectorsCommand}"/>
                                            <MenuItem Header="Edit Blocks..." Command="{Binding EditBlocksCommand}"/>
                                            <MenuItem Header="Save As Disk Image..." Command="{Binding SaveAsDiskImageCommand}"/>
                                            <MenuItem Header="Replace Partition Contents..." Command="{Binding ReplacePartitionCommand}"/>
                                            <MenuItem Header="Scan for Bad Blocks" Command="{Binding ScanForBadBlocksCommand}"/>
                                            <Separator/>
                                            <MenuItem Header="Scan for Sub-Volumes" Command="{Binding ScanForSubVolCommand}"/>
                                            <MenuItem Header="Defragment Filesystem" Command="{Binding DefragmentCommand}"/>
                                            <MenuItem Header="Close File Source" Command="{Binding CloseSubTreeCommand}"/>
                                        </ContextMenu>
                                    </TreeView.ContextMenu>
                                    <TreeView.ItemTemplate>
                                        <TreeDataTemplate ItemsSource="{Binding Items}">
                                            <StackPanel Orientation="Horizontal">
                                                <Image Source="{Binding StatusIcon}" IsVisible="{Binding StatusIcon, Converter={x:Static ObjectConverters.IsNotNull}}" Width="16" Height="16" Margin="0,0,2,0"/>
                                                <Image Source="{Binding ReadOnlyIcon}" IsVisible="{Binding ReadOnlyIcon, Converter={x:Static ObjectConverters.IsNotNull}}" Width="16" Height="16" Margin="0,0,2,0"/>
                                                <TextBlock Text="{Binding TypeStr}" Foreground="{DynamicResource ArchiveTypeTextBrush}"/>
                                                <TextBlock Text="{Binding Name}" Padding="6,0,2,0"/>
                                            </StackPanel>
                                        </TreeDataTemplate>
                                    </TreeView.ItemTemplate>
                                    <TreeView.Styles>
                                        <Style Selector="TreeViewItem">
                                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                        </Style>
                                    </TreeView.Styles>
                                </TreeView>
                            </Border>
                        </Grid>

                        <GridSplitter Grid.Row="1" Height="4"/>

                        <!-- Directory tree (bottom-left) -->
                        <Grid Grid.Row="2" Margin="4,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Directory" Margin="0,0,0,4" HorizontalAlignment="Center"/>
                            <Border Grid.Row="1" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="1" CornerRadius="2">
                                <TreeView Name="directoryTree" DragDrop.AllowDrop="True" ItemsSource="{Binding DirectoryTree.TreeRoot}" SelectionChanged="DirectoryTree_SelectionChanged">
                                    <TreeView.ContextMenu>
                                        <!-- Operates on the selected directory node. -->
                                        <ContextMenu>
                                            <MenuItem Header="Edit Directory Attributes..." Command="{Binding EditDirAttributesCommand}"/>
                                            <MenuItem Header="Paste" Command="{Binding PasteCommand}" InputGesture="Ctrl+V"/>
                                        </ContextMenu>
                                    </TreeView.ContextMenu>
                                    <TreeView.ItemTemplate>
                                        <TreeDataTemplate ItemsSource="{Binding Items}">
                                            <TextBlock Text="{Binding Name}"/>
                                        </TreeDataTemplate>
                                    </TreeView.ItemTemplate>
                                    <TreeView.Styles>
                                        <Style Selector="TreeViewItem">
                                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                        </Style>
                                    </TreeView.Styles>
                                </TreeView>
                            </Border>
                        </Grid>

                        <!-- Find panel (row 3): hidden until FindCommand is invoked -->
                        <Border Grid.Row="3" IsVisible="{Binding FindFileVM.IsFindPanelVisible}" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="0,1,0,0" Padding="4,4,4,4">
                            <Border BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="1" CornerRadius="3" Background="{DynamicResource SystemControlBackgroundAltHighBrush}" Padding="6,4,6,6">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <!-- Row 0: label + close button -->
                                    <Grid Grid.Row="0">
                                        <TextBlock Text="Find File" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <Button HorizontalAlignment="Right" Padding="4,0" FontSize="11" Content="✕" ToolTip.Tip="Close find panel" Command="{Binding FindFileVM.HideCommand}"/>
                                    </Grid>
                                    <!-- Row 1: text box + prev + next -->
                                    <Grid Grid.Row="1" Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Name="findFileTextBox" Text="{Binding FindFileVM.FileName, Mode=TwoWay}" Watermark="Filename…" FontFamily="{DynamicResource GeneralMonoFont}">
                                            <TextBox.KeyBindings>
                                                <KeyBinding Gesture="Enter" Command="{Binding FindFileVM.FindNextCommand}"/>
                                                <KeyBinding Gesture="Escape" Command="{Binding FindFileVM.HideCommand}"/>
                                            </TextBox.KeyBindings>
                                        </TextBox>
                                        <Button Grid.Column="1" Margin="4,0,0,0" Content="◀" ToolTip.Tip="Find Previous" Command="{Binding FindFileVM.FindPrevCommand}"/>
                                        <Button Grid.Column="2" Margin="4,0,0,0" Content="▶" ToolTip.Tip="Find Next" Command="{Binding FindFileVM.FindNextCommand}"/>
                                    </Grid>
                                    <!-- Row 2 (optional): current-archive-only checkbox -->
                                    <CheckBox Grid.Row="2" Content="Current archive only" Margin="0,4,0,0" IsChecked="{Binding FindFileVM.IsCurrentArchiveOnlyChecked}"/>
                                </Grid>
                            </Border>
                        </Border>
                    </Grid>
                    <Grid Grid.Column="2" Margin="0,4" Name="fileListPanel" DragDrop.AllowDrop="True" Background="Transparent">
                        <!-- Context menu for the empty area below the file rows (the DataGrid is
                             transparent there, so right-clicks fall through to this panel). When a
                             file is highlighted it mirrors the file row menu; with nothing selected
                             only the non-file items remain. Suppressed in info-panel mode via the
                             menu's Opening handler wired in code-behind. -->
                        <Grid.ContextMenu>
                            <ContextMenu Name="fileListPanelContextMenu">
                                <MenuItem Header="View Files" Command="{Binding ViewFilesCommand}" IsVisible="{Binding AreFileEntriesSelected}"/>
                                <MenuItem Header="_View Files in New Viewer" Command="{Binding ViewFilesInNewViewerCommand}" InputGesture="Ctrl+Enter" IsVisible="{Binding AreFileEntriesSelected}"/>
                                <MenuItem Header="Rename / Edit Attributes..." Command="{Binding EditAttributesCommand}" InputGesture="Alt+Enter" IsVisible="{Binding AreFileEntriesSelected}"/>
                                <MenuItem Header="Extract Files..." Command="{Binding ExtractFilesCommand}" IsVisible="{Binding AreFileEntriesSelected}"/>
                                <MenuItem Header="Export Files..." Command="{Binding ExportFilesCommand}" IsVisible="{Binding AreFileEntriesSelected}"/>
                                <MenuItem Header="Copy" Command="{Binding CopyCommand}" IsVisible="{Binding AreFileEntriesSelected}"/>
                                <MenuItem Header="Delete Files" Command="{Binding DeleteFilesCommand}" IsVisible="{Binding AreFileEntriesSelected}"/>
                                <MenuItem Header="Test Files" Command="{Binding TestFilesCommand}" IsVisible="{Binding AreFileEntriesSelected}"/>
                                <Separator IsVisible="{Binding AreFileEntriesSelected}"/>
                                <MenuItem Header="Add Files..." Command="{Binding AddFilesCommand}"/>
                                <MenuItem Header="Import Files..." Command="{Binding ImportFilesCommand}"/>
                                <MenuItem Header="Paste" Command="{Binding PasteCommand}"/>
                                <MenuItem Header="Create Directory..." Command="{Binding CreateDirectoryCommand}"/>
                            </ContextMenu>
                        </Grid.ContextMenu>
                        <!-- Center panel option 1: file list DataGrid -->
                        <DataGrid Name="fileListDataGrid" IsVisible="{Binding ShowCenterFileList}" ItemsSource="{Binding FileList.Items}" AutoGenerateColumns="False" ClipboardCopyMode="None" IsReadOnly="True" CanUserReorderColumns="False" CanUserResizeColumns="True" CanUserSortColumns="True" SelectionMode="Extended" GridLinesVisibility="Vertical" DragDrop.AllowDrop="True" DoubleTapped="FileListDataGrid_DoubleTapped" SelectionChanged="FileListDataGrid_SelectionChanged" Sorting="FileListDataGrid_Sorting">
                            <DataGrid.Styles>
                                <!-- Hide cell-level focus rectangle; row background highlight is sufficient -->
                                <Style Selector="DataGridCell:current /template/ Rectangle#CurrencyVisual">
                                    <Setter Property="IsVisible" Value="False"/>
                                </Style>
                                <Style Selector="DataGridCell:current /template/ Rectangle#CurrencyVisual2">
                                    <Setter Property="IsVisible" Value="False"/>
                                </Style>
                                <Style Selector="DataGridCell:current /template/ Rectangle#CurrentBackground">
                                    <Setter Property="IsVisible" Value="False"/>
                                </Style>

                                <Style Selector="DataGridCell:current /template/ Rectangle#CurrentBorder">
                                    <Setter Property="IsVisible" Value="False"/>
                                </Style>

                                <Style Selector="DataGridCell /template/ Grid#FocusVisual">
                                    <Setter Property="IsVisible" Value="False"/>
                                </Style>
                                <Style Selector="DataGridCell:focus">
                                    <Setter Property="BorderThickness" Value="0"/>
                                </Style>
                                <Style Selector="DataGridCell">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                </Style>



                                <!-- Smaller font for file details -->
                                <Style Selector="DataGridCell">
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="MinHeight" Value="20"/>
                                    <Setter Property="Height" Value="20"/>
                                </Style>
                                <Style Selector="DataGridColumnHeader">
                                    <Setter Property="FontSize" Value="12"/>
                                </Style>

                                <!-- The DataGrid package's own theme sets AllowAutoHide on its
                                     internal scrollbars closer to the control than our
                                     Application-level override, so it wins the tiebreak; repeat
                                     it here, local to this DataGrid, to win instead. -->
                                <Style Selector="ScrollViewer:not(:disabled)">
                                    <Setter Property="AllowAutoHide" Value="False"/>
                                </Style>
                                <Style Selector="ScrollBar:not(:disabled)">
                                    <Setter Property="AllowAutoHide" Value="False"/>
                                </Style>
                            </DataGrid.Styles>
                            <DataGrid.Columns>
                                <!-- Col 0: Status icon (dubious/damaged/comment) -->
                                <DataGridTemplateColumn Header="?" Width="Auto" CanUserResize="True" CanUserSort="True" IsVisible="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Image Source="{Binding StatusIcon}" Width="16"
                                                   IsVisible="{Binding StatusIcon, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                   ToolTip.Tip="{Binding StatusToolTip}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <!-- Col 1: Filename (shown in single-dir mode) -->
                                <!-- Note: DataGridColumn.IsVisible binding via parent DataContext
                                 does not work in Avalonia (columns are not in the visual tree).
                                 Visibility is set in code-behind via SetColumnVisible(). -->
                                <DataGridTemplateColumn Header="Filename" Width="Auto" CanUserResize="True" CanUserSort="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <!-- Col 2: Pathname (shown in full-list/archive mode) -->
                                <DataGridTemplateColumn Header="Pathname" Width="Auto" CanUserResize="True" CanUserSort="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding PathName}" TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <!-- Col 3-5: always visible -->
                                <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="Auto" CanUserResize="True"/>
                                <DataGridTextColumn Header="Auxtype" Binding="{Binding AuxType}" Width="Auto" CanUserResize="True"/>
                                <DataGridTextColumn Header="Mod Date" Binding="{Binding ModDate}" Width="Auto" CanUserResize="True"/>
                                <!-- Col 6: always visible -->
                                <DataGridTextColumn Header="Data Len" Binding="{Binding DataLength}" Width="Auto" CanUserResize="True"/>
                                <!-- Col 7: conditional (DOS 3.x raw files) -->
                                <DataGridTextColumn Header="Raw Len" Binding="{Binding RawDataLength}" Width="Auto" CanUserResize="True"/>
                                <!-- Col 8: conditional (archive format column) -->
                                <DataGridTextColumn Header="Data Fmt" Binding="{Binding DataFormat}" Width="Auto" CanUserResize="True"/>
                                <!-- Col 9: conditional (resource fork length) -->
                                <DataGridTextColumn Header="Rsrc Len" Binding="{Binding RsrcLength}" Width="Auto" CanUserResize="True"/>
                                <!-- Col 10: conditional (resource fork format) -->
                                <DataGridTextColumn Header="Rsrc Fmt" Binding="{Binding RsrcFormat}" Width="Auto" CanUserResize="True"/>
                                <!-- Col 11: conditional (total size for filesystems) -->
                                <DataGridTextColumn Header="Total Size" Binding="{Binding TotalSize}" Width="Auto" CanUserResize="True"/>
                                <!-- Col 12: always visible -->
                                <DataGridTextColumn Header="Access" Binding="{Binding Access}" Width="Auto" CanUserResize="True"/>
                            </DataGrid.Columns>
                            <!-- TODO: drag &amp; drop support -->
                            <DataGrid.ContextMenu>
                                <!-- TODO: ContextMenuOpening refocus handler -->
                                <ContextMenu>
                                    <MenuItem Header="View Files" Command="{Binding ViewFilesCommand}"/>
                                    <MenuItem Header="_View Files in New Viewer" Command="{Binding ViewFilesInNewViewerCommand}" InputGesture="Ctrl+Enter"/>

                                    <MenuItem Header="Rename / Edit Attributes..." Command="{Binding EditAttributesCommand}" InputGesture="Alt+Enter"/>
                                    <MenuItem Header="Extract Files..." Command="{Binding ExtractFilesCommand}"/>
                                    <MenuItem Header="Export Files..." Command="{Binding ExportFilesCommand}"/>
                                    <MenuItem Header="Copy" Command="{Binding CopyCommand}"/>
                                    <MenuItem Header="Paste" Command="{Binding PasteCommand}"/>
                                    <MenuItem Header="Delete Files" Command="{Binding DeleteFilesCommand}"/>
                                    <MenuItem Header="Test Files" Command="{Binding TestFilesCommand}"/>
                                    <Separator/>
                                    <MenuItem Header="Add Files..." Command="{Binding AddFilesCommand}"/>
                                    <MenuItem Header="Import Files..." Command="{Binding ImportFilesCommand}"/>
                                    <MenuItem Header="Create Directory..." Command="{Binding CreateDirectoryCommand}"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                        </DataGrid>

                        <ScrollViewer IsVisible="{Binding ShowCenterInfoPanel}">
                            <StackPanel Margin="8">
                                <TextBlock Text="{Binding CenterInfo.CenterInfoText1}" TextWrapping="Wrap" FontWeight="Bold" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding CenterInfo.CenterInfoText2}" TextWrapping="Wrap" IsVisible="{Binding CenterInfo.CenterInfoText2, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" Foreground="{DynamicResource InfoWarningTextBrush}" Margin="0,0,0,8"/>
                                <!-- Info key/value list -->
                                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}" BorderThickness="1" CornerRadius="2" Padding="4" HorizontalAlignment="Left">
                                    <ItemsControl ItemsSource="{Binding CenterInfo.CenterInfoList}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="120"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{Binding Name}" FontWeight="SemiBold"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Value}" TextWrapping="Wrap"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>

                                <!-- Disk / Partition Utilities -->
                                <Border IsVisible="{Binding CenterInfo.ShowDiskUtilityButtons}" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}" BorderThickness="1" CornerRadius="2" Margin="0,8,0,0" Padding="4" HorizontalAlignment="Left">
                                    <StackPanel>
                                        <TextBlock Text="Disk / Partition Utilities" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Button Content="Edit Sectors" Grid.Row="0" Grid.Column="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Command="{Binding EditSectorsCommand}"/>
                                            <Button Content="Edit Blocks" Grid.Row="1" Grid.Column="0" Margin="0,4,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Command="{Binding EditBlocksCommand}"/>
                                            <Button Content="Save As Disk Image" Grid.Row="0" Grid.Column="2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Command="{Binding SaveAsDiskImageCommand}"/>
                                            <Button Content="Replace Partition Contents" Grid.Row="1" Grid.Column="2" Margin="0,4,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Command="{Binding ReplacePartitionCommand}"/>
                                            <Button Content="Scan For Bad Blocks" Grid.Row="2" Grid.Column="0" Margin="0,4,0,0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Command="{Binding ScanForBadBlocksCommand}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Partition Layout -->
                                <StackPanel IsVisible="{Binding CenterInfo.ShowPartitionLayout}" Margin="0,8,0,0">
                                    <TextBlock Text="Partition Layout:" Margin="0,0,0,4"/>
                                    <DataGrid Name="partitionLayoutDataGrid" ItemsSource="{Binding CenterInfo.PartitionList}" MaxHeight="400" IsReadOnly="True" GridLinesVisibility="Vertical" AutoGenerateColumns="False" HeadersVisibility="Column" CanUserReorderColumns="False" CanUserResizeColumns="True" DoubleTapped="PartitionLayout_DoubleTapped" Sorting="InfoDataGrid_Sorting">
                                        <DataGrid.Columns>
                                            <!-- Auto-size to content/header; do not hard-code widths.
                                                 Avalonia's font metrics and control padding differ from
                                                 WPF, so ported pixel widths clip or misalign here. -->
                                            <DataGridTextColumn Header="#" Width="Auto" CanUserResize="True" Binding="{Binding Index}"/>
                                            <DataGridTextColumn Header="Start Block" Width="Auto" CanUserResize="True" Binding="{Binding StartBlock}"/>
                                            <DataGridTextColumn Header="Block Count" Width="Auto" CanUserResize="True" Binding="{Binding BlockCount}"/>
                                            <DataGridTextColumn Header="Name" Width="Auto" CanUserResize="True" Binding="{Binding PartName}"/>
                                            <DataGridTextColumn Header="Type" Width="*" CanUserResize="True" Binding="{Binding PartType}"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>

                                <!-- Metadata -->
                                <StackPanel IsVisible="{Binding CenterInfo.ShowMetadata}" Margin="0,8,0,0">
                                    <TextBlock Text="Metadata:" Margin="0,0,0,4"/>
                                    <DataGrid Name="metadataDataGrid" ItemsSource="{Binding CenterInfo.MetadataItems}" MaxHeight="400" IsReadOnly="True" GridLinesVisibility="Vertical" AutoGenerateColumns="False" HeadersVisibility="Column" CanUserReorderColumns="False" CanUserResizeColumns="True" DoubleTapped="MetadataList_DoubleTapped" Sorting="InfoDataGrid_Sorting">
                                        <DataGrid.Columns>
                                            <DataGridTemplateColumn Header="Key" Width="150" CanUserResize="True">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Key}" Foreground="{Binding TextForeground}" ToolTip.Tip="{Binding Description}"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="Value" Width="*" CanUserResize="True">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Value}" Foreground="{Binding TextForeground}" ToolTip.Tip="{Binding ValueSyntax}"/>
                                                    </DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <Button Margin="0,8,0,0" Width="120" Content="Add New Entry" IsEnabled="{Binding CenterInfo.CanAddMetadataEntry}" Click="Metadata_AddEntryButtonClick"/>
                                </StackPanel>

                                <!-- Notes -->
                                <StackPanel IsVisible="{Binding CenterInfo.ShowNotes}" Margin="0,8,0,0">
                                    <TextBlock Text="Notes:" Margin="0,0,0,4"/>
                                    <DataGrid ItemsSource="{Binding CenterInfo.NotesList}" MaxHeight="400" IsReadOnly="True" GridLinesVisibility="Vertical" AutoGenerateColumns="False" HeadersVisibility="Column" CanUserReorderColumns="False" PointerPressed="InfoDataGrid_PointerPressed" Sorting="InfoDataGrid_Sorting">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Prio" Width="32" Binding="{Binding TypeChar}"/>
                                            <DataGridTextColumn Header="Message" Width="*" Binding="{Binding Text}"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- Right panel: options panel.  Sized by the Show/Hide button only.  The
                         ScrollViewer has a fixed expanded width (rather than Auto, so the panel
                         doesn't resize when combo-box content changes); toggling the "collapsed"
                         class animates its Width/Opacity to zero (and the button rotates), leaving
                         the panel at just the rotated button.  See ScrollViewer.optionsPanelScroll
                         styles in Window.Styles. -->
                    <Border Grid.Column="3" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="1" CornerRadius="2" Margin="2,4,0,4">
                        <DockPanel>
                            <LayoutTransformControl DockPanel.Dock="Bottom" HorizontalAlignment="Center" Margin="2,2">
                                <LayoutTransformControl.LayoutTransform>
                                    <RotateTransform Angle="{Binding Options.ShowHideRotation}">
                                        <RotateTransform.Transitions>
                                            <Transitions>
                                                <DoubleTransition Property="Angle" Duration="0:0:0.25" Easing="CubicEaseInOut"/>
                                            </Transitions>
                                        </RotateTransform.Transitions>
                                    </RotateTransform>
                                </LayoutTransformControl.LayoutTransform>
                                <Button Content="Show/Hide Settings" Width="160" Click="ShowHideOptionsButton_Click"/>
                            </LayoutTransformControl>
                            <ScrollViewer DockPanel.Dock="Top" Classes="optionsPanelScroll" Classes.collapsed="{Binding !Options.ShowOptionsPanel}" HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Margin="2">
                                    <!-- Add/Import Options header -->
                                    <Border Background="{DynamicResource SectionHeaderBrush}" Margin="0,0,0,2">
                                        <TextBlock Text="Add/Import Options" HorizontalAlignment="Center" Padding="2"/>
                                    </Border>
                                    <StackPanel Margin="2,4,2,0">
                                        <CheckBox Content="Recurse Into Directories" IsChecked="{Binding Options.AddRecurse}"/>
                                        <CheckBox Content="Use Compression" IsChecked="{Binding Options.AddCompress}"/>
                                        <CheckBox Content="Strip Paths" IsChecked="{Binding Options.AddStripPaths}"/>
                                        <CheckBox Content="Raw (for DOS 3.x)" IsChecked="{Binding Options.AddRaw}"/>
                                        <common:GroupBox Header="Preservation Handling" Margin="0,4,0,0">
                                            <StackPanel>
                                                <CheckBox Content="AppleSingle" IsChecked="{Binding Options.AddPreserveAS}"/>
                                                <CheckBox Content="AppleDouble" IsChecked="{Binding Options.AddPreserveADF}"/>
                                                <CheckBox Content="NAPS" IsChecked="{Binding Options.AddPreserveNAPS}"/>
                                            </StackPanel>
                                        </common:GroupBox>
                                        <common:GroupBox Header="Import Configuration" Margin="0,4,0,0">
                                            <StackPanel>
                                                <CheckBox Content="Strip Redundant Extensions" IsChecked="{Binding Options.AddStripExt}" Margin="0,2,0,0"/>
                                                <TextBlock Text="Conversion mode:" Margin="0,4,0,0"/>
                                                <ComboBox Margin="0,4,0,0" ItemsSource="{Binding Options.ImportConverters}" SelectedItem="{Binding Options.SelectedImportConverter}" DisplayMemberBinding="{Binding Label}"/>
                                                <Button Margin="0,4,0,0" HorizontalAlignment="Center" Content="Conversion Settings" Command="{Binding Options.ConfigureImportSettingsCommand}"/>
                                            </StackPanel>
                                        </common:GroupBox>
                                    </StackPanel>

                                    <!-- Extract/Export Options header -->
                                    <Border Background="{DynamicResource SectionHeaderBrush}" Margin="0,16,0,2">
                                        <TextBlock Text="Extract/Export Options" HorizontalAlignment="Center" Padding="2"/>
                                    </Border>
                                    <StackPanel Margin="2,4,2,0">
                                        <CheckBox Content="Strip Paths" IsChecked="{Binding Options.ExtStripPaths}"/>
                                        <CheckBox Content="Add Filename Ext to Exports" IsChecked="{Binding Options.ExtAddExportExt}"/>
                                        <CheckBox Content="Raw (for DOS 3.x)" IsChecked="{Binding Options.ExtRaw}"/>
                                        <common:GroupBox Header="Preservation Mode" Margin="0,4,0,0">
                                            <StackPanel>
                                                <RadioButton Content="None" GroupName="ExtPreserve" IsChecked="{Binding Options.ExtPreserveNone}"/>
                                                <RadioButton Content="AppleSingle" GroupName="ExtPreserve" IsChecked="{Binding Options.ExtPreserveAS}"/>
                                                <RadioButton Content="AppleDouble" GroupName="ExtPreserve" IsChecked="{Binding Options.ExtPreserveADF}"/>
                                                <RadioButton Content="NAPS" GroupName="ExtPreserve" IsChecked="{Binding Options.ExtPreserveNAPS}"/>
                                            </StackPanel>
                                        </common:GroupBox>
                                        <common:GroupBox Header="Export Configuration" Margin="0,4,0,8">
                                            <StackPanel>
                                                <TextBlock Text="Conversion mode:"/>
                                                <RadioButton Content="Best (automatic)" GroupName="ExportCfg" Margin="0,4,0,0" IsChecked="{Binding Options.IsExportBestChecked}"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <RadioButton Grid.Column="0" Margin="0,8,0,0" GroupName="ExportCfg" IsChecked="{Binding Options.IsExportComboChecked}"/>
                                                    <ComboBox Grid.Column="1" Margin="0,4,0,0" ItemsSource="{Binding Options.ExportConverters}" SelectedItem="{Binding Options.SelectedExportConverter}" DisplayMemberBinding="{Binding Label}"/>
                                                </Grid>
                                                <Button Margin="0,4,0,0" HorizontalAlignment="Center" Content="Conversion Settings" Command="{Binding Options.ConfigureExportSettingsCommand}"/>
                                            </StackPanel>
                                        </common:GroupBox>
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>
        </DockPanel>

        <!-- Toast notification: overlaid at bottom-center, hidden by default -->
        <Border Name="toastBorder" IsVisible="False" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,40" Padding="16,8" CornerRadius="6" Background="#C800A000">
            <TextBlock Name="toastText" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center"/>
        </Border>

    </Grid>

</Window>
