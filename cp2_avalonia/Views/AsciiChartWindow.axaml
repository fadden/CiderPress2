<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        x:Class="cp2_avalonia.Views.AsciiChartWindow"
        mc:Ignorable="d"
        Title="ASCII Chart"
        Width="505"
        Height="620"
        MinWidth="460"
        MinHeight="420"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <Grid RowDefinitions="*,Auto" Margin="10">
        <TextBox Grid.Row="0"
                 Name="asciiChartTextBox"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="NoWrap"
                 FontFamily="{DynamicResource GeneralMonoFont}"
                 FontSize="{DynamicResource ViewerDefaultFontSize}"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 ScrollViewer.VerticalScrollBarVisibility="Auto" />
        <ComboBox Grid.Row="1"
                  Name="asciiRangeComboBox"
                  Margin="0,10,0,0"
                  Width="120"
                  HorizontalAlignment="Left"
                  SelectionChanged="AsciiRangeComboBox_SelectionChanged">
            <ComboBoxItem Content="Low ASCII" />
            <ComboBoxItem Content="High ASCII" />
        </ComboBox>
    </Grid>
</Window>