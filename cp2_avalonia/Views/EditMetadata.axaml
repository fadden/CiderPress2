<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="cp2_avalonia.Views.EditMetadata"
        Title="Edit Metadata"
        Width="400" SizeToContent="Height" CanResize="False"
        ShowInTaskbar="False" WindowStartupLocation="CenterOwner"
        Opened="Window_Opened">

    <Window.Styles>
        <Style Selector="TextBlock.invalid">
            <Setter Property="Foreground" Value="Red"/>
        </Style>
    </Window.Styles>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Key:"/>
        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding KeyText}" Margin="8,1,0,0"
                 FontFamily="{DynamicResource GeneralMonoFont}" IsReadOnly="True"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,4,0,0"
                   Text="{Binding DescriptionText, FallbackValue=Description_Here}"
                   TextWrapping="Wrap"/>

        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,12,0,0" Text="Value:"/>
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="valueTextBox" Margin="8,13,0,0"
                 Text="{Binding ValueText, Mode=TwoWay}"
                 FontFamily="{DynamicResource GeneralMonoFont}"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,4,0,0"
                   Text="{Binding ValueSyntaxText, FallbackValue=Syntax_here}"
                   TextWrapping="Wrap" Classes.invalid="{Binding !IsValueValid}"/>

        <Button Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Width="70" Margin="0,8,0,0"
                HorizontalAlignment="Left" Content="Delete" IsEnabled="{Binding CanDelete}"
                Command="{Binding DeleteCommand}"/>

        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                    Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button x:Name="okButton" Content="OK" IsDefault="True" Width="70"
                    IsEnabled="{Binding IsValid}" Command="{Binding OkCommand}"/>
            <Button x:Name="cancelButton" Content="Cancel" IsCancel="True"
                    Width="70" Margin="4,0,0,0" Command="{Binding CancelCommand}"/>
        </StackPanel>
    </Grid>
</Window>
