<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="cp2_avalonia.Views.FindFile"
        Title="Find File"
        Width="400" SizeToContent="Height" CanResize="False"
        ShowInTaskbar="False" WindowStartupLocation="CenterOwner"
        Opened="Window_Opened">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Filename:"/>
            <TextBox x:Name="fileNameTextBox" Grid.Column="1" Margin="4,1,0,0"
                     Text="{Binding FileName, Mode=TwoWay, FallbackValue=FileName_Here}"
                     FontFamily="{DynamicResource GeneralMonoFont}"/>
        </Grid>

        <CheckBox Grid.Row="1" Content="Current archive only" Margin="0,6,0,0"
                  IsChecked="{Binding IsCurrentArchiveOnlyChecked}"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="findPrev" Content="Find Previous" Width="100"
                    Command="{Binding FindPrevCommand}"/>
            <Button x:Name="findNext" Content="Find Next" Width="100" Margin="4,0,0,0"
                    Command="{Binding FindNextCommand}"
                    IsDefault="True"/>
            <Button x:Name="cancelButton" Content="Cancel" IsCancel="True"
                    Width="70" Margin="4,0,0,0" Command="{Binding CloseCommand}"/>
        </StackPanel>
    </Grid>
</Window>
