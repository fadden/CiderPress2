<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="cp2_avalonia.Controls.GroupBox">
    <StackPanel>
        <TextBlock Text="{Binding Header, RelativeSource={RelativeSource AncestorType=UserControl}}"
                   FontWeight="SemiBold" Margin="6,0,0,0"/>
        <Border BorderBrush="{DynamicResource ThemeBorderLowBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="8"
                Margin="0,2,0,4">
            <ContentPresenter Content="{Binding Content, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
        </Border>
    </StackPanel>
</UserControl>
