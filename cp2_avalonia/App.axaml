<Application x:Class="cp2_avalonia.App"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:common="clr-namespace:cp2_avalonia.Common"
             xmlns:controls="clr-namespace:cp2_avalonia.Controls"
             Name="CiderPress II">
    <!-- macOS system app menu (the bold first entry in the menu bar).
         On Windows/Linux, NativeMenu.Menu on Application is ignored.
         Items here appear directly in the app menu — no wrapper NativeMenuItem needed. -->
    <NativeMenu.Menu>
        <NativeMenu>
            <NativeMenuItem Header="About CiderPress II"
                            Click="OnNativeAboutClick"/>
            <NativeMenuItemSeparator/>
            <NativeMenuItem Header="Settings..."
                            Click="OnNativeSettingsClick"/>
        </NativeMenu>
    </NativeMenu.Menu>
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml" />
        <!-- Fade icon images when their parent toolbar button is disabled.
             Must live here (not in Icons.axaml) because ResourceDictionary
             cannot host free-standing selector styles. -->
        <Style Selector="Button:disabled Image">
            <Setter Property="Opacity"
                    Value="{DynamicResource IconDisabledOpacity}" />
        </Style>
        <Style Selector="DataGridCell">
            <Setter Property="Padding"
                    Value="1,0" />
            <Setter Property="FontSize"
                    Value="12" />
            <Setter Property="VerticalContentAlignment"
                    Value="Center" />
            <!-- Compact row height, matching the file-list grid, so all DataGrids share a
                 consistent row height. -->
            <Setter Property="MinHeight"
                    Value="20" />
            <Setter Property="Height"
                    Value="20" />
        </Style>
        <Style Selector="DataGridColumnHeader">
            <Setter Property="Padding"
                    Value="1,1" />
            <Setter Property="FontSize"
                    Value="12" />
        </Style>
        <Style Selector="TreeViewItem">
            <!-- Reduce the vertical padding -->
            <Setter Property="Padding"
                    Value="2,2" />
            <!-- Reduce the minimum row height -->
            <Setter Property="MinHeight"
                    Value="20" />
        </Style>
        <Style Selector="TabItem">
            <Setter Property="FontSize"
                    Value="14" />
                    <Setter Property="Padding"
                    Value="6,2" />
        </Style>
        <Style Selector="Button"><Setter Property="HorizontalContentAlignment" Value="Center"/></Style>

        <!-- Avalonia's overlay scrollbars auto-hide down to a thin resting-state bar that
             still overlaps content (there's no gap reserved for it), which reads as broken
             text rendering rather than an obvious scrollbar. Keeping them always at full
             size avoids that; overlapping content while at full size (i.e. while being
             actively scrolled/dragged) is an acceptable, obviously-a-scrollbar tradeoff.
             ":not(:disabled)" is a no-op filter (virtually every ScrollViewer is enabled) but
             its conditional pseudo-class promotes this Setter from "Style" to "StyleTrigger"
             priority, needed to win over any AllowAutoHide default that TreeView/DataGrid/
             ListBox set on their internal ScrollViewer via "Template" priority. -->
        <Style Selector="ScrollViewer:not(:disabled)">
            <Setter Property="AllowAutoHide" Value="False"/>
        </Style>
        <Style Selector="ScrollBar:not(:disabled)">
            <Setter Property="AllowAutoHide" Value="False"/>
        </Style>

    </Application.Styles>
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://CiderPress2/Res/Icons.axaml" />
            </ResourceDictionary.MergedDictionaries>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="SectionHeaderBrush" Color="LightSteelBlue"/>
                    <SolidColorBrush x:Key="SubSectionHeaderBrush" Color="#E6EEF8"/>
                    <SolidColorBrush x:Key="ArchiveTypeTextBrush" Color="Green"/>
                    <SolidColorBrush x:Key="InfoWarningTextBrush" Color="OrangeRed"/>
                    <SolidColorBrush x:Key="ViewerBackgroundBrush" Color="White"/>
                    <SolidColorBrush x:Key="ViewerInverseForegroundBrush" Color="White"/>
                    <SolidColorBrush x:Key="ViewerInverseBackgroundBrush" Color="Black"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="SectionHeaderBrush" Color="#3D5A80"/>
                    <SolidColorBrush x:Key="SubSectionHeaderBrush" Color="#2A3A50"/>
                    <SolidColorBrush x:Key="ArchiveTypeTextBrush" Color="#66BB6A"/>
                    <SolidColorBrush x:Key="InfoWarningTextBrush" Color="#FF8A65"/>
                    <SolidColorBrush x:Key="ViewerBackgroundBrush" Color="#3F3F3F"/>
                    <SolidColorBrush x:Key="ViewerInverseForegroundBrush" Color="#3F3F3F"/>
                    <SolidColorBrush x:Key="ViewerInverseBackgroundBrush" Color="White"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            <!-- Cross-platform monospace fallback chain: Win (Cascadia/Consolas), macOS (Menlo/Monaco), Linux (DejaVu/Liberation/Noto). -->
            <FontFamily x:Key="GeneralMonoFont">Cascadia Mono, Consolas, Menlo, Monaco, DejaVu Sans Mono, Liberation Mono, Noto Sans Mono, monospace</FontFamily>
            <FontFamily x:Key="ViewerMonoFont">Cascadia Mono, Consolas, Menlo, Monaco, DejaVu Sans Mono, Liberation Mono, Noto Sans Mono, monospace</FontFamily>
            <!-- Monospace serif (Courier-style): Courier New (Win/macOS), Liberation Mono (Linux) -->
            <FontFamily x:Key="ViewerMonoSerifFont">Courier New, Courier, Liberation Mono, DejaVu Sans Mono, monospace</FontFamily>
            <!-- Proportional serif: Georgia (Win/macOS/common Linux), Liberation Serif (Linux), Times New Roman (Win/macOS) -->
            <FontFamily x:Key="ViewerSerifFont">Georgia, Times New Roman, Liberation Serif, Times, serif</FontFamily>
            <!-- Proportional sans-serif: Arial (Win/macOS), Liberation Sans (Linux), Helvetica (macOS/Unix) -->
            <FontFamily x:Key="ViewerSansSerifFont">Arial, Helvetica, Liberation Sans, sans-serif</FontFamily>
            <x:Double x:Key="ViewerDefaultFontSize">13</x:Double>
            <!-- Icon brushes and disabled opacity: initial defaults for Light theme.
                 These are updated imperatively in App.ApplyTheme() on every theme switch
                 because DynamicResource in ThemeDictionaries does not reliably re-resolve. -->
            <SolidColorBrush x:Key="IconForegroundBrush" Color="#212121"/>
            <SolidColorBrush x:Key="IconForegroundFillBrush" Color="#212121" Opacity="0.1"/>
            <x:Double x:Key="IconDisabledOpacity">0.4</x:Double>
            <x:Double x:Key="ControlContentThemeFontSize">14</x:Double>
            <common:InverseBooleanConverter x:Key="InvertBool" />
            <!-- Checkerboard background for bitmap image display.
                 Replicates the pattern from cp2_wpf/App.xaml: 16x16 tile with #e8e8e8/#f0f0f0. -->
            <DrawingBrush x:Key="CheckerBackground"
                          TileMode="Tile"
                          DestinationRect="0,0,16,16">
                <DrawingBrush.Drawing>
                    <DrawingGroup>
                        <GeometryDrawing Geometry="M0,0 H2 V2 H0Z"
                                         Brush="#B8B8B8" />
                        <GeometryDrawing Geometry="M0,0 H1 V1 H2 V2 H1 V1 H0Z"
                                         Brush="#9A9A9A" />
                    </DrawingGroup>
                </DrawingBrush.Drawing>
            </DrawingBrush>
            <!-- GroupBox: a HeaderedContentControl that draws a labeled border around content.
                 Avalonia has no built-in GroupBox; this ControlTheme supplies the visual. -->
            <ControlTheme x:Key="{x:Type controls:GroupBox}" TargetType="controls:GroupBox">
                <!-- Defaults; any GroupBox may override BorderBrush/BorderThickness/CornerRadius/Padding. -->
                <Setter Property="Padding" Value="8"/>
                <Setter Property="BorderBrush" Value="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="4"/>
                <Setter Property="Template">
                    <ControlTemplate>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Bordered content area; its top edge runs behind the header title.
                                 The top margin drops the border line to the vertical middle of the
                                 title; the presenter's top margin keeps content clear of the title. -->
                            <Border Grid.Row="0" Grid.RowSpan="2"
                                    Margin="0,10,0,4"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    Background="{TemplateBinding Background}">
                                <ContentPresenter Name="PART_ContentPresenter"
                                                  Margin="0,6,0,0"
                                                  Padding="{TemplateBinding Padding}"
                                                  Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </Border>

                            <!-- Header title sits on top of the border line (ZIndex 1); its
                                 background masks the line behind it, giving the notched look.
                                 The background must match the dialog background. -->
                            <Border Grid.Row="0" ZIndex="1"
                                    HorizontalAlignment="Left"
                                    Margin="8,0,0,0"
                                    Padding="4,0"
                                    Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
                                <TextBlock Text="{TemplateBinding Header}"
                                           FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter>
            </ControlTheme>
        </ResourceDictionary>
    </Application.Resources>
</Application>